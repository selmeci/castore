{
  "name": "@castore/core",
  "license": "MIT",
  "homepage": "https://github.com/castore-dev/castore#readme",
  "bugs": "https://github.com/castore-dev/castore/issues",
  "repository": "castore-dev/castore.git",
  "keywords": [
    "event",
    "source",
    "store",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "scripts": {
    "lint-fix": "eslint --fix",
    "lint-fix-all": "pnpm run lint-fix .",
    "package": "rm -rf dist && pnpm run package-cjs && pnpm run package-esm && pnpm run package-types",
    "package-cjs": "NODE_ENV=cjs pnpm run transpile --out-dir dist/cjs --source-maps --out-file-extension .cjs",
    "package-esm": "NODE_ENV=esm pnpm run transpile --out-dir dist/esm --source-maps --out-file-extension .mjs",
    "package-types": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "test": "pnpm run test-type && pnpm run test-unit && pnpm run test-circular && pnpm run test-linter",
    "test-circular": "depcruise --validate .dependency-cruiser.js .",
    "test-linter": "eslint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false",
    "test-unit": "vitest run --passWithNoTests",
    "transpile": "babel src --extensions .ts --quiet",
    "watch": "rm -rf dist && concurrently 'npm:package-* --watch'"
  },
  "dependencies": {
    "@babel/runtime": "^7.28.4",
    "ts-toolbelt": "^9.6.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.3",
    "@babel/core": "^7.28.4",
    "@babel/plugin-transform-runtime": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.27.1",
    "@types/node": "^24.5.2",
    "babel-plugin-module-resolver": "^4.1.0",
    "concurrently": "^9.2.1",
    "dependency-cruiser": "^17.0.1",
    "eslint": "^9.36.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./*": {
      "types": "./dist/types/*.d.ts",
      "import": "./dist/esm/*.mjs",
      "require": "./dist/cjs/*.cjs",
      "default": "./dist/esm/*.mjs"
    }
  },
  "maintainers": [
    "Thomas Aribart",
    "Charles Géry",
    "Juliette Fournier",
    "Valentin Beggi",
    "Stanislas Hannebelle"
  ],
  "type": "module"
}
