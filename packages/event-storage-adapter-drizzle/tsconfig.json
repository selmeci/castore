{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "src",
    "composite": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "esModuleInterop": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "~/*": ["*"],
      "pg": ["../node_modules/@types/pg"]
    }
  },
  "exclude": ["./dist"],
  "include": ["./**/*.ts"]
}
