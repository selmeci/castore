{
  "targetDefaults": {
    "build": {
      "dependsOn": ["^package"],
      "outputs": ["{projectRoot}/build", "{projectRoot}/dist"],
      "cache": true
    },
    "package": {
      "dependsOn": ["^package"],
      "outputs": ["{projectRoot}/dist"],
      "cache": true
    },
    "test": {
      "dependsOn": ["^package"],
      "cache": true
    },
    "test-linter": {
      "dependsOn": ["^package"],
      "cache": true
    },
    "test-type": {
      "dependsOn": ["^package"],
      "cache": true
    },
    "test-unit": {
      "dependsOn": ["^package"],
      "cache": true
    }
  },
  "extends": "@nx/workspace/presets/npm.json",
  "defaultBase": "main"
}
