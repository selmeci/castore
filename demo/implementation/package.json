{
  "name": "@castore/demo-implementation",
  "license": "UNLICENSED",
  "sideEffects": false,
  "scripts": {
    "deploy": "env-cmd sls deploy",
    "deploy-function": "env-cmd sls deploy function -f",
    "invoke-local": "env-cmd sls invoke local -f",
    "lint-fix": "eslint --fix",
    "lint-fix-all": "pnpm run lint-fix .",
    "log": "env-cmd sls logs -t -f",
    "print": "env-cmd sls print",
    "test": "pnpm run test-type && pnpm run test-unit && pnpm run test-circular && pnpm run test-linter",
    "test-circular": "depcruise --validate .dependency-cruiser.js .",
    "test-linter": "eslint .",
    "test-type": "tsc --noEmit --emitDeclarationOnly false",
    "test-unit": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.893.0",
    "@castore/core": "workspace:*",
    "@castore/demo-blueprint": "workspace:*",
    "@castore/event-storage-adapter-dynamodb": "workspace:*",
    "@middy/core": "^3.6.2",
    "@middy/validator": "^3.6.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@castore/lib-test-tools": "workspace:*",
    "@serverless/typescript": "^3.38.0",
    "@types/aws-lambda": "^8.10.152",
    "@types/http-errors": "^1.8.2",
    "@types/serverless": "^3.12.27",
    "dependency-cruiser": "^17.0.1",
    "env-cmd": "^11.0.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.36.0",
    "json-schema-to-ts": "^3.1.1",
    "mockdate": "^3.0.5",
    "serverless": "^3.40.0",
    "serverless-esbuild": "^1.55.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
