strict-peer-dependencies=true
auto-install-peers=false
resolution-mode=highest

# onlyBuiltDependencies allow-list is fail-closed for unknown packages.
# Every addition requires security review. husky does not need an entry — it
# is a root devDep invoked by the root postinstall script, which always runs
# regardless of pnpm's fail-closed gate.
only-built-dependencies[]=esbuild
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=core-js
only-built-dependencies[]=core-js-pure
only-built-dependencies[]=tree-sitter
only-built-dependencies[]=tree-sitter-json
only-built-dependencies[]=@tree-sitter-grammars/tree-sitter-yaml
only-built-dependencies[]=nx
# better-sqlite3: native postinstall builds the SQLite binary. Required by
# the sqlite drizzle adapter's unit tests (drizzle-orm/better-sqlite3 driver).
only-built-dependencies[]=better-sqlite3

# public-hoist-pattern — required for TypeScript type resolution under strict
# pnpm. Each entry is load-bearing and must carry justification:
#
# - vitest: root tsconfig.json sets types: ["node", "vitest/globals"], which
#   applies to every package. Workspaces that don't themselves run vitest
#   (docs, demo/visualization) still need the types reachable for tsc.
# - @castore/event-type-json-schema, json-schema-to-ts: leaked transitively
#   through @castore/demo-blueprint's exported EventStore types. Without
#   hoisting, TS2742 "non-portable inference" fires in demo-implementation
#   and lib-dam. Declaring them as direct devDeps would misrepresent the
#   dependency graph (no direct imports).
public-hoist-pattern[]=vitest
public-hoist-pattern[]=@castore/event-type-json-schema
public-hoist-pattern[]=json-schema-to-ts
# webpack: Docusaurus 3's bundler pipeline fails with a ProgressPlugin
# ValidationError under pnpm's strict graph because internal plugins import
# webpack transitively via multiple @docusaurus/* subtrees, confusing the
# plugin instance identity. Public-hoisting webpack ensures a single
# resolved instance.
public-hoist-pattern[]=webpack
