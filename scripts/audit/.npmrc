# Side-worktree-only .npmrc for pnpm dep-hygiene audit (PR 1).
# Intentionally stricter than production config — surfaces phantom deps
# and peer issues that Yarn 4's nodeLinker: node-modules hoisting hides.
#
# Do NOT copy this file to the main worktree. The production .npmrc
# (added in PR 2) shares the strict flags but also adds the
# onlyBuiltDependencies[] allow-list which is determined by Unit 2 output.

strict-peer-dependencies=true
auto-install-peers=false
resolution-mode=highest
